---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contacto | NEXUS Digital">

  <!-- HERO -->
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/4 right-1/3 w-72 h-72 rounded-full bg-accent/5 blur-[100px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">mail</span>Contacto</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5">
            Construyamos tu próxima <span class="gradient-text">historia de éxito</span> digital
          </h1>
          <p class="text-body-lg text-text-secondary">
            Cuéntanos tu proyecto y en menos de 24 horas un especialista de NEXUS te contactará con una propuesta estratégica personalizada.
          </p>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=500&q=80"
              alt="Contacto NEXUS Digital"
              class="w-full aspect-square object-cover opacity-80"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section class="bg-bg-depth py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-14 items-start">
        <!-- Left: info -->
        <div class="reveal">
          <h2 class="font-display text-headline-lg-mobile md:text-headline-md mb-4">Envíanos un mensaje</h2>
          <p class="text-text-secondary text-body-md mb-8 leading-relaxed">
            Estamos listos para transformar tu visión en una realidad digital impactante. Déjanos tus datos y un especialista se pondrá en contacto contigo en menos de 24 horas.
          </p>
          <div class="space-y-5 mb-10">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-accent text-base">mail</span>
              </div>
              <div>
                <p class="text-text-dim text-xs uppercase tracking-widest font-display font-semibold mb-0.5">Email</p>
                <p class="text-text-primary text-sm">hola@nexusdigital.io</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-accent text-base">call</span>
              </div>
              <div>
                <p class="text-text-dim text-xs uppercase tracking-widest font-display font-semibold mb-0.5">Teléfono</p>
                <p class="text-text-primary text-sm">+34 639 494 000</p>
              </div>
            </div>
          </div>
          <div>
            <p class="tag-cyber mb-4">Redes Sociales</p>
            <div class="flex gap-3">
              <a href="#" class="glass p-3 rounded-xl hover:border-accent/40 transition-all" aria-label="Instagram">
                <span class="material-symbols-outlined text-text-secondary hover:text-accent transition-colors text-xl">photo_camera</span>
              </a>
              <a href="#" class="glass p-3 rounded-xl hover:border-accent/40 transition-all" aria-label="LinkedIn">
                <span class="material-symbols-outlined text-text-secondary hover:text-accent transition-colors text-xl">business</span>
              </a>
              <a href="#" class="glass p-3 rounded-xl hover:border-accent/40 transition-all" aria-label="Twitter/X">
                <span class="material-symbols-outlined text-text-secondary hover:text-accent transition-colors text-xl">public</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="reveal">
          <div class="glass lumen-border rounded-2xl p-8">
            <form class="space-y-5" novalidate>
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Nombre Completo</label>
                  <input type="text" placeholder="Tu nombre" class="input-cyber" />
                </div>
                <div>
                  <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Email Corporativo</label>
                  <input type="email" placeholder="tu@empresa.com" class="input-cyber" />
                </div>
              </div>
              <div>
                <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Motivo de Consulta</label>
                <select class="input-cyber">
                  <option value="" disabled selected>Selecciona un servicio</option>
                  <option value="web">Desarrollo Web</option>
                  <option value="estrategia">Estrategia Digital</option>
                  <option value="seo">SEO &amp; SEM</option>
                  <option value="otro">Otro</option>
                </select>
              </div>
              <div>
                <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Mensaje</label>
                <textarea rows="4" placeholder="Cuéntanos sobre tu proyecto..." class="input-cyber resize-none"></textarea>
              </div>
              <button type="submit" class="btn-cyber-solid w-full justify-center magnetic press">
                SOLICITAR ASESORÍA
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP STRIP -->
  <section class="mesh-bg-alt py-16">
    <div class="max-w-container-max mx-auto px-gutter flex justify-center">
      <div class="glass lumen-border rounded-2xl px-8 py-5 flex items-center gap-4">
        <span class="material-symbols-outlined text-accent text-2xl">location_on</span>
        <div>
          <p class="font-display font-bold text-text-primary">Visítanos en Madrid, España</p>
          <p class="text-text-secondary text-sm">Disponibles para reuniones presenciales y videollamadas</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

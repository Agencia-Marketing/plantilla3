---
import Layout from '../layouts/Layout.astro';

const services = [
  { icon: 'code',          title: 'Desarrollo Web',         desc: 'Plataformas digitales de alto rendimiento, diseñadas para convertir visitantes en clientes desde el primer clic.', href: '/servicios/desarrollo-web' },
  { icon: 'smart_toy',     title: 'Agentes de IA',          desc: 'Automatiza tu atención al cliente y cualificación de leads con agentes inteligentes activos las 24 horas.', href: '/servicios/agentes-ia' },
  { icon: 'palette',       title: 'Diseño Gráfico',         desc: 'Identidades visuales que comunican autoridad y generan reconocimiento inmediato en cualquier punto de contacto.', href: '/servicios/diseno-grafico' },
  { icon: 'diversity_3',   title: 'Gestión de Redes',       desc: 'Estrategia, contenido y comunidad: convertimos tus redes sociales en un canal de ventas y fidelización.', href: '/servicios/redes-sociales' },
  { icon: 'ads_click',     title: 'Campañas de Ads',        desc: 'Publicidad digital de precisión quirúrgica en Google y Meta para captar clientes listos para comprar.', href: '/servicios/campanas-publicitarias' },
  { icon: 'movie',         title: 'Videomarketing',         desc: 'Piezas audiovisuales estratégicas que potencian tu mensaje y disparan el engagement de tu audiencia.', href: '/servicios/videomarketing' },
  { icon: 'filter_alt',    title: 'Embudos de Venta',       desc: 'Sistemas de conversión automatizados que guían a tus prospectos hasta la compra con mínima fricción.', href: '/servicios/embudos-venta' },
  { icon: 'campaign',      title: 'Creadores UGC',          desc: 'Conectamos tu marca con creadores reales para campañas que generan confianza y aumentan conversiones.', href: '/servicios/creadores-ugc' },
  { icon: 'history_edu',   title: 'Creación de Contenido',  desc: 'Contenido estratégico y optimizado que posiciona tu marca como referente y atrae tráfico cualificado.', href: '/servicios/creacion-contenido' },
];

const reasons = [
  { icon: 'workspace_premium', title: 'Experiencia Comprobada',   desc: 'Años de historial ejecutando campañas de alto impacto en mercados competitivos, con resultados documentados.' },
  { icon: 'groups',            title: 'Equipo Elite',              desc: 'Especialistas certificados en cada disciplina digital, alineados bajo una única estrategia de crecimiento para tu negocio.' },
  { icon: 'lightbulb',         title: 'Innovación Constante',      desc: 'Incorporamos las últimas herramientas y tendencias — IA, automatización y datos — para mantener tu ventaja competitiva.' },
  { icon: 'trending_up',       title: 'Resultados Medibles',       desc: 'Todo lo que hacemos está orientado a métricas reales: tráfico, leads, ventas y retorno sobre inversión.' },
];
---
<Layout title="NEXUS Digital | Agencia Digital de Alto Rendimiento">

  <!-- HERO -->
  <section class="mesh-bg relative min-h-screen flex items-center pt-24 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/4 right-1/4 w-96 h-96 rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 left-1/4 w-80 h-80 rounded-full bg-grad-violet/10 blur-[100px] pointer-events-none"></div>

    <div class="max-w-container-max mx-auto px-gutter w-full">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="tag-cyber mb-6 inline-flex"><span class="material-symbols-outlined text-sm">bolt</span>Agencia Digital Premium</span>
          <h1 class="font-display text-display-hero-mobile md:text-display-hero mb-6">
            Lleva tu marca al <span class="gradient-text">siguiente nivel</span> de impacto digital
          </h1>
          <p class="text-body-lg text-text-secondary mb-8 max-w-xl">
            En NEXUS combinamos tecnología de vanguardia con estrategia creativa para transformar tu presencia digital en resultados medibles y sostenibles.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="#servicios" class="btn-cyber-solid magnetic press">
              <span class="icon-wrap">Explorar servicios <span class="material-symbols-outlined text-base">arrow_downward</span></span>
            </a>
            <a href="/contacto" class="btn-ghost magnetic press">Háblanos</a>
          </div>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img
              src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=600&q=80"
              alt="Equipo NEXUS Digital trabajando en estrategia digital"
              class="w-full aspect-[4/3] object-cover opacity-90"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="servicios" class="bg-bg-depth py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-16 reveal">
        <span class="tag-cyber mb-4 inline-flex">Servicios</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-4">Soluciones que <span class="gradient-text">transforman</span> tu negocio</h2>
        <p class="text-body-md text-text-secondary max-w-2xl mx-auto">Cada servicio está diseñado para atacar un punto clave de tu crecimiento digital con precisión y eficiencia.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-fade">
        {services.map(s => (
          <a href={s.href} class="glass card-cyber rounded-2xl p-7 group block">
            <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-5 group-hover:bg-accent/20 transition-colors duration-300">
              <span class="material-symbols-outlined text-accent text-2xl">{s.icon}</span>
            </div>
            <h3 class="font-display text-headline-md mb-3 group-hover:text-accent transition-colors duration-300">{s.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-5">{s.desc}</p>
            <span class="inline-flex items-center gap-2 text-accent text-sm font-display font-semibold">
              + Más info <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY NEXUS -->
  <section class="mesh-bg py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-16 reveal">
        <span class="tag-cyber mb-4 inline-flex">Por qué elegirnos</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg">Por qué confiar en <span class="gradient-text">NEXUS</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6 stagger-fade">
        {reasons.map(r => (
          <div class="glass card-cyber rounded-2xl p-8">
            <span class="material-symbols-outlined text-accent text-3xl mb-4 block">{r.icon}</span>
            <h3 class="font-display text-headline-md mb-3">{r.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="bg-bg-depth py-section-py-sm">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="glass lumen-border rounded-3xl p-12 md:p-16 text-center reveal"
           style="background: linear-gradient(135deg, rgba(79,70,229,0.10) 0%, rgba(0,240,255,0.05) 100%);">
        <span class="tag-cyber mb-6 inline-flex">¿Listo para crecer?</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-5">
          NEXUS es tu mejor <span class="gradient-text">decisión estratégica</span>
        </h2>
        <p class="text-text-secondary text-body-md max-w-xl mx-auto mb-8">
          Nuestro enfoque personalizado y orientado a datos nos permite ejecutar estrategias que realmente mueven la aguja de tu negocio.
        </p>
        <a href="/contacto" class="btn-cyber-solid magnetic press inline-flex">
          <span class="icon-wrap">Iniciar proyecto <span class="material-symbols-outlined text-base">rocket_launch</span></span>
        </a>
      </div>
    </div>
  </section>

</Layout>

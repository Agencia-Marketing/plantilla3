---
import Layout from '../../layouts/Layout.astro';

const features = [
  { icon: 'strategy', title: 'Estrategia Definida', desc: 'Plan de contenidos mensual alineado con tus objetivos de negocio y tu audiencia.' },
  { icon: 'trending_up', title: 'Crecimiento Escalable', desc: 'Metodología probada para aumentar seguidores reales y engagement mes a mes.' },
  { icon: 'auto_awesome', title: 'Contenido Innovador', desc: 'Piezas gráficas, reels y copies optimizados para cada plataforma y su algoritmo.' },
];

const plans = [
  {
    name: 'Plan Esencial',
    sub: 'Para negocios que comienzan',
    price: '$2,470 MXN/mes',
    features: ['3 posts por semana', '1 red social', 'Community manager', 'Reporte mensual'],
    featured: false,
  },
  {
    name: 'Plan Profesional',
    sub: 'Para negocios en crecimiento',
    price: '$4,990 MXN/mes',
    features: ['5 posts por semana', '2 redes sociales', 'Stories incluidas', 'Community manager', 'Reporte quincenal'],
    featured: false,
  },
  {
    name: 'Plan Avanzado',
    sub: 'Para marcas con ambición',
    price: '$7,990 MXN/mes',
    features: ['7 posts por semana', '3 redes sociales', 'Reels incluidos', 'Community manager', 'Estrategia editorial', 'Reporte semanal'],
    featured: true,
  },
  {
    name: 'Plan Premium',
    sub: 'Para líderes del sector',
    price: '$12,990 MXN/mes',
    features: ['Posts diarios', '4 redes sociales', 'Colaboración influencers', 'Reels + stories', 'Estrategia completa', 'Reporte en tiempo real'],
    featured: false,
  },
  {
    name: 'Plan Elite',
    sub: 'Equipo de contenido dedicado',
    price: '$25,000 MXN/mes',
    features: ['Equipo completo de contenido', '5 redes sociales', 'Producción audiovisual', 'Estrategia 360°', 'Manager dedicado', 'Dashboard exclusivo'],
    featured: false,
  },
  {
    name: 'Master Plan Élite',
    sub: 'Dominio total del mercado',
    price: '$78,000 MXN/mes',
    features: ['Todo lo de Plan Elite', 'Campañas pagadas incluidas', 'Influencer marketing', 'PR digital', 'Analítica avanzada', 'Soporte prioritario 24/7'],
    featured: false,
  },
];
---
<Layout title="Redes Sociales | NEXUS Digital">
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/3 right-1/4 w-80 h-80 rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">diversity_3</span>Gestión de Redes</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5">
            Transforma tus redes en un <span class="gradient-text">motor de ventas</span> recurrentes
          </h1>
          <p class="text-body-lg text-text-secondary mb-8">Estrategia, contenido y comunidad: convertimos tus redes sociales en un canal de ventas y fidelización que trabaja contigo 24/7.</p>
          <div class="flex gap-4 flex-wrap">
            <a href="/contacto" class="btn-cyber-solid magnetic press">Solicitar servicio</a>
            <a href="#planes" class="btn-ghost magnetic press">Ver planes</a>
          </div>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img src="https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?w=600&q=80" alt="Redes Sociales NEXUS" class="w-full aspect-video object-cover opacity-80" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-14">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-3 gap-5 stagger-fade">
        {features.map(f => (
          <div class="glass card-cyber rounded-2xl p-7">
            <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-accent text-2xl">{f.icon}</span>
            </div>
            <h3 class="font-display font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="planes" class="mesh-bg py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">Planes</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg">Planes y <span class="gradient-text">precios</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-fade">
        {plans.map(p => (
          <div class={`glass card-cyber rounded-2xl p-7 flex flex-col ${p.featured ? 'lumen-border scale-105 relative' : ''}`}>
            {p.featured && <span class="tag-cyber mb-4 self-start">Más Popular</span>}
            <p class="font-display font-bold text-xl mb-1">{p.name}</p>
            <p class="text-text-secondary text-sm mb-3">{p.sub}</p>
            <p class="gradient-text font-display font-extrabold text-2xl mb-5">{p.price}</p>
            <ul class="space-y-2 mb-6 flex-1">
              {p.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="material-symbols-outlined text-accent text-base mt-0.5 flex-shrink-0">check_circle</span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contacto" class={p.featured ? 'btn-cyber-solid w-full justify-center text-center' : 'btn-ghost w-full justify-center text-center'}>Contratar</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-section-py-sm">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="glass lumen-border rounded-3xl p-12 text-center reveal" style="background: linear-gradient(135deg, rgba(79,70,229,0.10) 0%, rgba(0,240,255,0.05) 100%);">
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-4">¿Te convencemos?</h2>
        <p class="text-text-secondary mb-8 max-w-xl mx-auto">Agenda una llamada gratuita de 30 minutos y definimos juntos la estrategia de redes que necesita tu negocio.</p>
        <a href="/contacto" class="btn-cyber-solid magnetic press inline-flex">
          <span class="icon-wrap">Hablar con un experto <span class="material-symbols-outlined text-base">phone_in_talk</span></span>
        </a>
      </div>
    </div>
  </section>
</Layout>

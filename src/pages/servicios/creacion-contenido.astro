---
import Layout from '../../layouts/Layout.astro';

const features = [
  { icon: 'search', title: 'SEO Integrado', desc: 'Cada pieza está optimizada con palabras clave estratégicas para posicionar en Google y atraer tráfico orgánico.' },
  { icon: 'palette', title: 'Consistencia Visual', desc: 'Línea gráfica coherente en todos los formatos: artículos, infografías, posts y carruseles.' },
  { icon: 'military_tech', title: 'Autoridad de Marca', desc: 'Contenido de valor que convierte tu marca en referente de la industria y genera confianza.' },
];

const plans = [
  {
    name: 'Pack Básico',
    sub: 'Para comenzar con contenido',
    price: '$1,990 MXN',
    features: ['1 diseño gráfico premium', 'Copywriting incluido', '2 revisiones', 'Licencia de uso'],
    featured: false,
  },
  {
    name: 'Pack Mensual',
    sub: 'El más solicitado',
    price: '$9,990 MXN',
    features: ['15 diseños/mes', 'Calendario editorial', 'Copywriting SEO', '3 rondas de revisiones', 'Reporte mensual'],
    featured: true,
  },
  {
    name: 'Pack Profesional',
    sub: 'Para marcas en expansión',
    price: '$12,990 MXN',
    features: ['20 diseños/mes', 'Estrategia de contenidos', 'Vídeos cortos x4', 'Copywriting premium', 'Soporte prioritario'],
    featured: false,
  },
  {
    name: 'Pack Enterprise',
    sub: 'Dominio total de contenido',
    price: '$18,990 MXN',
    features: ['30 diseños/mes', 'Content strategy completo', 'Vídeos cortos x8', 'Blog posts x4/mes', 'Manager dedicado', 'Informe semanal'],
    featured: false,
  },
];
---
<Layout title="Creación de Contenido | NEXUS Digital">
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/3 right-1/4 w-80 h-80 rounded-full bg-accent/5 blur-[120px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">history_edu</span>Creación de Contenido</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5">
            Contenido que <span class="gradient-text">posiciona, educa</span> y convierte tu audiencia
          </h1>
          <p class="text-body-lg text-text-secondary mb-8">Contenido estratégico y optimizado para SEO que posiciona tu marca como referente de autoridad y atrae tráfico cualificado mes a mes.</p>
          <div class="flex gap-4 flex-wrap">
            <a href="/contacto" class="btn-cyber-solid magnetic press">Solicitar servicio</a>
            <a href="#planes" class="btn-ghost magnetic press">Ver planes</a>
          </div>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80" alt="Creación de Contenido NEXUS" class="w-full aspect-video object-cover opacity-80" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-14">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-3 gap-5 stagger-fade">
        {features.map(f => (
          <div class="glass card-cyber rounded-2xl p-7">
            <div class="w-12 h-12 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-accent text-2xl">{f.icon}</span>
            </div>
            <h3 class="font-display font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="planes" class="mesh-bg py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-14 reveal">
        <span class="tag-cyber mb-4 inline-flex">Planes</span>
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg">Planes y <span class="gradient-text">precios</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 stagger-fade">
        {plans.map(p => (
          <div class={`glass card-cyber rounded-2xl p-7 flex flex-col ${p.featured ? 'lumen-border scale-105 relative' : ''}`}>
            {p.featured && <span class="tag-cyber mb-4 self-start">Más Popular</span>}
            <p class="font-display font-bold text-xl mb-1">{p.name}</p>
            <p class="text-text-secondary text-sm mb-3">{p.sub}</p>
            <p class="gradient-text font-display font-extrabold text-2xl mb-5">{p.price}</p>
            <ul class="space-y-2 mb-6 flex-1">
              {p.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="material-symbols-outlined text-accent text-base mt-0.5 flex-shrink-0">check_circle</span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contacto" class={p.featured ? 'btn-cyber-solid w-full justify-center text-center' : 'btn-ghost w-full justify-center text-center'}>Contratar</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg-depth py-section-py-sm">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="glass lumen-border rounded-3xl p-12 text-center reveal" style="background: linear-gradient(135deg, rgba(79,70,229,0.10) 0%, rgba(0,240,255,0.05) 100%);">
        <h2 class="font-display text-headline-lg-mobile md:text-headline-lg mb-4">¿Te convencemos?</h2>
        <p class="text-text-secondary mb-8 max-w-xl mx-auto">Agenda una consulta gratuita de 30 minutos y diseñamos juntos la estrategia de contenidos que posicionará tu marca.</p>
        <a href="/contacto" class="btn-cyber-solid magnetic press inline-flex">
          <span class="icon-wrap">Hablar con un experto <span class="material-symbols-outlined text-base">phone_in_talk</span></span>
        </a>
      </div>
    </div>
  </section>
</Layout>
